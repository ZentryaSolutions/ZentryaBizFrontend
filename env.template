# Create React App — copy this file to `.env` inside the `frontend/` folder (same level as package.json).
# Restart `npm start` after any change. Vars are baked in at build time (Vercel needs a redeploy too).

REACT_APP_BACKEND_URL=https://YOUR_API_HOST/api

REACT_APP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# New Supabase publishable key (sb_publishable_...) or legacy anon JWT (eyJ...):
REACT_APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Optional alias (either this or PUBLISHABLE_KEY is enough):
# REACT_APP_SUPABASE_ANON_KEY=
